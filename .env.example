# Modo de execução (standalone = MongoDB embarcado | api = backend externo)
TYPE=standalone

# Next.js
NEXT_PORT=3000
ENV=development

# URL pública do site (usada em robots.txt e sitemap.xml)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MongoDB (apenas para o modo standalone)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=cms

# API (apenas para o modo api)
API_URL=
